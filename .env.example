# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://agrosense_user:yourpassword@localhost:5432/agrosense_db

# ─── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─── Google Earth Engine ─────────────────────────────────────────────────────
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=secrets/gee-key.json

#___ Gmail ______________________________________________________________________
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ADMIN_EMAIL=your-admin@gmail.com
